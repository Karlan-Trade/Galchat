# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.dart text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.xml text eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.otf binary
*.ttf binary
*.apk binary
*.aab binary
